{
  "name": "Test",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "ID do tenant (cl\u00ednica)"
    },
    "test_number": {
      "type": "string",
      "description": "N\u00famero do teste"
    },
    "client_id": {
      "type": "string",
      "description": "ID do cliente"
    },
    "client_name": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "Data de in\u00edcio do teste"
    },
    "start_time": {
      "type": "string",
      "description": "Hor\u00e1rio de in\u00edcio do teste"
    },
    "end_date": {
      "type": "string",
      "format": "date",
      "description": "Data final do teste"
    },
    "end_time": {
      "type": "string",
      "description": "Hor\u00e1rio final do teste"
    },
    "devices": {
      "type": "array",
      "description": "Aparelhos utilizados no teste",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "serial_number": {
            "type": "string"
          }
        }
      }
    },
    "professional_id": {
      "type": "string",
      "description": "ID do profissional respons\u00e1vel"
    },
    "professional_name": {
      "type": "string",
      "description": "Nome do profissional respons\u00e1vel"
    },
    "referral_professional_id": {
      "type": "string",
      "description": "ID do profissional de indica\u00e7\u00e3o"
    },
    "referral_professional_name": {
      "type": "string",
      "description": "Nome do profissional de indica\u00e7\u00e3o"
    },
    "status": {
      "type": "string",
      "enum": [
        "teste_agendado",
        "em_teste",
        "teste_estendido",
        "teste_finalizado",
        "teste_pendente"
      ],
      "default": "em_teste",
      "description": "Status do teste"
    },
    "notes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es"
    }
  },
  "required": [
    "client_id",
    "start_date",
    "end_date"
  ],
  "rls": {
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}