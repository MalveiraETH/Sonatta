{
  "name": "Installment",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "ID do tenant (cl\u00ednica)"
    },
    "sale_id": {
      "type": "string",
      "description": "ID da venda"
    },
    "sale_number": {
      "type": "string",
      "description": "N\u00famero da venda"
    },
    "client_id": {
      "type": "string",
      "description": "ID do cliente"
    },
    "client_name": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "pix_parcelado",
        "cartao_credito"
      ],
      "description": "M\u00e9todo de pagamento"
    },
    "card_brand": {
      "type": "string",
      "description": "Bandeira do cart\u00e3o"
    },
    "fee_rate": {
      "type": "number",
      "default": 0,
      "description": "Taxa do cart\u00e3o (%)"
    },
    "fee_amount": {
      "type": "number",
      "default": 0,
      "description": "Valor da taxa (R$) nesta parcela"
    },
    "gross_amount": {
      "type": "number",
      "default": 0,
      "description": "Valor bruto da parcela"
    },
    "net_amount": {
      "type": "number",
      "default": 0,
      "description": "Valor l\u00edquido da parcela (bruto - taxa)"
    },
    "installments_total": {
      "type": "number",
      "description": "Total de parcelas"
    },
    "installment_number": {
      "type": "number",
      "description": "N\u00famero da parcela"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Data de vencimento"
    },
    "original_amount": {
      "type": "number",
      "description": "Valor bruto da parcela (legado)"
    },
    "paid_amount": {
      "type": "number",
      "default": 0,
      "description": "Valor j\u00e1 pago"
    },
    "remaining_amount": {
      "type": "number",
      "description": "Saldo devedor"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "pendente",
        "parcialmente_pago",
        "pago",
        "atrasado"
      ],
      "default": "pendente",
      "description": "Status do pagamento"
    },
    "last_payment_date": {
      "type": "string",
      "format": "date",
      "description": "Data do \u00faltimo pagamento"
    },
    "payment_history": {
      "type": "array",
      "description": "Hist\u00f3rico de pagamentos",
      "items": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "amount": {
            "type": "number"
          },
          "note": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "sale_id",
    "client_id",
    "payment_method",
    "due_date",
    "original_amount"
  ],
  "rls": {}
}