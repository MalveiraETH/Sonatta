{
  "name": "MessageTemplate",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome do template (ex: Adultos \u2014 Alta Prioridade (Padr\u00e3o))"
    },
    "message_type": {
      "type": "string",
      "enum": [
        "padrao",
        "campanha"
      ],
      "default": "padrao",
      "description": "Tipo: padrao = envio individual, campanha = disparo em massa"
    },
    "age_group": {
      "type": "string",
      "enum": [
        "bebes",
        "criancas",
        "adultos"
      ],
      "description": "Grupo et\u00e1rio alvo"
    },
    "priority": {
      "type": "string",
      "enum": [
        "alta",
        "media",
        "baixa",
        "todas"
      ],
      "default": "todas",
      "description": "Prioridade alvo (ou todas)"
    },
    "message": {
      "type": "string",
      "description": "Texto da mensagem. Use {{nome}} para o primeiro nome do cliente e {{aparelho}} para o aparelho testado."
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Se o template est\u00e1 ativo"
    }
  },
  "required": [
    "name",
    "age_group",
    "message"
  ],
  "rls": {
    "read": true,
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}